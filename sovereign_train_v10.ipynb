    "    obs = env.reset(task)\n",
    "    for _ in range(10): \n",
    "        obs, r, done, _ = env.step('{\"tool\":\"check_calendar\",\"params\":{}}')\n",
    "    print(f\"{task.upper()}: {env.grader():.3f}\")\n",
    "\n",
    "# Push model - requires valid HF Token from Cell 1\n",
    "try:\n",
    "    model.push_to_hub(\"ManojR19/sovereign-agent-v10\", token=True)\n",
    "    tokenizer.push_to_hub(\"ManojR19/sovereign-agent-v10\", token=True)\n",
    "    print(\"✅ HF Hub Sync Complete: https://huggingface.co/ManojR19/sovereign-agent-v10\")\n",
